{% extends 'base.html.twig' %}

{% block title %}Dirty Cars API{% endblock %}

{% block body %}
<style>
    body {
        background-color: #000;
        color: white;
        font-family: Arial, sans-serif;
        margin: 0;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    .wrapper {
        margin: 2em auto;
        max-width: 900px;
        width: 95%;
        font-size: 18px;
    }
      .header {
        display: flex;
        align-items: center;
        gap: 10px;
    }
  
    footer {
        background-color: #111;
        color: white;
        text-align: center;
        padding: 1em 0;
        margin-top: auto;
        width: 100%;
    }
</style>

<div class="wrapper">

    <div class="header">
        <img src="/images/icon.png" alt="Dirty Cars Logo">
        <h1>Dirty Cars API!</h1>
    </div>
</div>
<footer>
    <p>&copy; 2025 Dirty Cars API. All rights reserved.</p>
</footer>
{% endblock %}
